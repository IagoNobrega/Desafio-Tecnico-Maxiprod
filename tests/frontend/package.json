    "@types/node": "^20.10.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.7",
